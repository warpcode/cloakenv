# Example cloakenv template file (.env format)
# Map environment variables to secret URIs or literal values

# Resolve from OS Keyring
DB_PASSWORD=${keyring://my_service/db_password}

# Resolve from a config-defined vault path
API_SECRET=${work://production/api_keys:client_secret}

# Pass-through literal value
APP_PORT=8080
LOG_LEVEL="info"
